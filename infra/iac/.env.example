## Copy this file to .env and fill the values. Keep .env out of version control.
# Example .env for Terraform Azure service principal authentication
AZURE_CLIENT_ID="your-service-principal-client-id"
AZURE_CLIENT_SECRET="your-service-principal-client-secret"
AZURE_TENANT_ID="your-tenant-id"
AZURE_SUBSCRIPTION_ID="your-subscription-id"


# Optional: if you prefer to use Azure CLI, leave the values empty and run 'az login'
#AZ_USE_AZ_CLI=true
